<script>
  // ── Reading progress bar (scaleX, not width) ───────────────────────
  const bar = document.getElementById('read-progress');
  if (bar) {
    const onScroll = () => {
      const doc = document.documentElement;
      const max = doc.scrollHeight - doc.clientHeight;
      const pct = max > 0 ? doc.scrollTop / max : 0;
      bar.style.transform = `scaleX(${pct})`;
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // ── Copy link button ──────────────────────────────────────────────
  const copyBtn = document.getElementById('copy-link-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', () => {
      const label = copyBtn.querySelector('.copy-label') as HTMLElement | null;
      navigator.clipboard.writeText(window.location.href).then(() => {
        if (!label) return;
        const orig = (copyBtn as HTMLElement).dataset.copy ?? label.textContent ?? '';
        label.textContent = (copyBtn as HTMLElement).dataset.copied ?? label.textContent ?? '';
        setTimeout(() => { label.textContent = orig; }, 2000);
      });
    });
  }

  // ── Scroll-spy TOC ─────────────────────────────────────────────────
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('#toc-nav .sidebar-link');
  const headingEls: HTMLElement[] = [];
  tocLinks.forEach(link => {
    const href = link.getAttribute('href') || '';
    if (!href.startsWith('#')) return;
    const target = document.getElementById(href.slice(1));
    if (target instanceof HTMLElement) headingEls.push(target);
  });
  if (headingEls.length > 0) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(l => l.classList.remove('active'));
          const active = document.querySelector(`#toc-nav .sidebar-link[href="#${entry.target.id}"]`);
          if (active) active.classList.add('active');
        }
      });
    }, { rootMargin: '-20% 0px -70% 0px' });
    headingEls.forEach(h => observer.observe(h));
  }

  // ── Reveal animation ───────────────────────────────────────────────
  const revealEls = document.querySelectorAll('.reveal');
  if ('IntersectionObserver' in window) {
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          revealObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    revealEls.forEach(el => revealObserver.observe(el));
  } else {
    revealEls.forEach(el => el.classList.add('visible'));
  }
</script>
