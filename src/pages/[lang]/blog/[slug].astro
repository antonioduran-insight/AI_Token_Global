---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getAllPostSlugs, getPostBySlug, getRelatedPosts } from '../../../lib/sanity';
import { useTranslations, LANG_META, isValidLang } from '../../../i18n/index';
import type { Lang } from '../../../i18n/index';
import type { SanityPost } from '../../../lib/sanity';
import { toHTML } from '@portabletext/to-html';

export async function getStaticPaths() {
  const slugs = await getAllPostSlugs();
  return slugs.map(({ slug, lang }) => ({
    params: { lang, slug },
  }));
}

const { lang, slug } = Astro.params;
if (!isValidLang(lang)) return Astro.redirect('/en/blog');

const t = useTranslations(lang as Lang);
const post: SanityPost | null = await getPostBySlug(slug as string, lang);
if (!post) return Astro.redirect(`/${lang}/blog`);

const related: SanityPost[] = await getRelatedPosts(post.slug.current, lang, post.category, 3);

const CATEGORIES = [
  { value: 'fundamentals', label: t('blog.cat.fundamentals') },
  { value: 'compliance',   label: t('blog.cat.compliance') },
  { value: 'calculation',  label: t('blog.cat.calculation') },
  { value: 'pricing',      label: t('blog.cat.pricing') },
  { value: 'models',       label: t('blog.cat.models') },
  { value: 'platform',     label: t('blog.cat.platform') },
  { value: 'tutorials',    label: t('blog.cat.tutorials') },
];
const CAT_PILL: Record<string, string> = {
  fundamentals: 'purple',
  compliance:   'dark',
  calculation:  'purple',
  pricing:      'blue',
  models:       'blue',
  platform:     'amber',
  tutorials:    'green',
};
const CAT_GRADIENT: Record<string, string> = {
  fundamentals: 'linear-gradient(135deg, #6155F1, #2A1F5C)',
  compliance:   'linear-gradient(135deg, #3C315B, #0D1547)',
  calculation:  'linear-gradient(135deg, #6155F1, #2A1F5C)',
  pricing:      'linear-gradient(135deg, #3E81E5, #0D1547)',
  models:       'linear-gradient(135deg, #3E81E5, #0D1547)',
  platform:     'linear-gradient(135deg, #B07D2E, #4A2B0F)',
  tutorials:    'linear-gradient(135deg, #2D8653, #0F4030)',
};
const CAT_TINT: Record<string, string> = {
  fundamentals: 'rgba(97,85,241,0.4)',
  compliance:   'rgba(60,49,91,0.45)',
  calculation:  'rgba(97,85,241,0.4)',
  pricing:      'rgba(62,129,229,0.4)',
  models:       'rgba(62,129,229,0.4)',
  platform:     'rgba(176,125,46,0.45)',
  tutorials:    'rgba(45,134,83,0.4)',
};

function catLabel(value?: string) {
  if (!value) return '';
  return CATEGORIES.find(c => c.value === value)?.label ?? value;
}
function catPill(value?: string) {
  if (!value) return 'purple';
  return CAT_PILL[value] ?? 'purple';
}
function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString(LANG_META[lang as Lang].locale, { year: 'numeric', month: 'long', day: 'numeric' });
}

// ── Word count + reading time ──────────────────────────────────────────────
function blockText(block: any): string {
  if (!block || !Array.isArray(block.children)) return '';
  return block.children.map((c: any) => c?.text ?? '').join('');
}
function countWords(blocks: any[]): number {
  let total = 0;
  for (const block of blocks ?? []) {
    if (block?._type !== 'block') continue;
    const text = blockText(block);
    if (!text) continue;
    total += text.trim().split(/\s+/).filter(Boolean).length;
  }
  return total;
}
const wordCount = countWords(post.body || []);
const readingMinutes = Math.max(1, Math.round(wordCount / 225));
const readingLabel = t('blog.minRead').replace('{n}', String(readingMinutes));

// ── Collect h2 headings for TOC ────────────────────────────────────────────
const usedSlugs = new Set<string>();
function slugify(text: string) {
  const base = text.toLowerCase().replace(/[^\p{L}\p{N}]+/gu, '-').replace(/^-+|-+$/g, '');
  let s = base || 'section';
  let i = 2;
  while (usedSlugs.has(s)) s = `${base}-${i++}`;
  usedSlugs.add(s);
  return s;
}
const headings: { id: string; text: string }[] = [];
for (const block of post.body || []) {
  if (block?._type === 'block' && block?.style === 'h2') {
    const text = blockText(block).trim();
    if (!text) continue;
    headings.push({ id: slugify(text), text });
  }
}
// Reset for the render pass below so we generate matching IDs.
usedSlugs.clear();

const bodyHtml = post.body ? toHTML(post.body, {
  components: {
    block: {
      h2: ({ value, children }) => {
        const text = blockText(value).trim();
        const id = slugify(text);
        return `<h2 id="${id}">${children}</h2>`;
      },
      h3: ({ value, children }) => {
        const text = blockText(value).trim();
        const id = slugify(text);
        return `<h3 id="${id}">${children}</h3>`;
      },
    },
    types: {
      image: ({ value }) => {
        const url = value?.asset?.url ?? value?.url ?? '';
        const alt = value?.alt ?? '';
        const caption = value?.caption ?? '';
        if (!url) return '';
        return `<figure class="article-figure"><img src="${url}" alt="${alt}" />${caption ? `<figcaption>${caption}</figcaption>` : ''}</figure>`;
      },
      codeBlock: ({ value }) => {
        const codeLang = value?.language ?? '';
        const code = (value?.code ?? '').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        return `<pre><code class="language-${codeLang}">${code}</code></pre>`;
      },
    },
  },
}) : '';

const siteOrigin = (Astro.site ?? new URL('https://www.aitoken.global')).origin;
const postUrl = `${siteOrigin}/${lang}/blog/${post.slug.current}`;

const heroPill = catPill(post.category);
const heroCategoryLabel = catLabel(post.category);
const coverGradient = post.category ? CAT_GRADIENT[post.category] ?? CAT_GRADIENT.fundamentals : CAT_GRADIENT.fundamentals;
const coverTint = post.category ? CAT_TINT[post.category] ?? CAT_TINT.fundamentals : CAT_TINT.fundamentals;
---

<BaseLayout
  title={`${post.title} — AI Token King ${t('nav.blog')}`}
  description={post.excerpt}
  activePage="blog"
  lang={lang as Lang}
>

  <!-- Reading progress bar -->
  <div id="read-progress" aria-hidden="true"></div>

  <!-- ═══════════════════════════════ HERO / POST HEADER ═══════════════════════════════ -->
  <section class="post-hero">
    <div class="post-hero-inner">

      <!-- Breadcrumb -->
      <nav class="post-breadcrumb" aria-label={t('common.aria.breadcrumb')}>
        <a href={`/${lang}/`}>{t('common.home')}</a>
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 4l4 4-4 4" stroke="#CCC" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <a href={`/${lang}/blog`}>{t('nav.blog')}</a>
        {heroCategoryLabel && (
          <>
            <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 4l4 4-4 4" stroke="#CCC" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="post-breadcrumb-current">{heroCategoryLabel}</span>
          </>
        )}
      </nav>

      <div class="post-hero-col">

        <!-- Tags -->
        <div class="fade-up post-hero-tags">
          {post.category && (
            <a href={`/${lang}/blog`} class={`tag-pill tag-${heroPill}`}>{heroCategoryLabel}</a>
          )}
          {post.tags && post.tags.slice(0, 1).map(tag => (
            <a href={`/${lang}/blog`} class="tag-pill tag-blue">{tag}</a>
          ))}
        </div>

        <!-- Title -->
        <h1 class="fade-up fade-up-1 post-title">{post.title}</h1>

        <!-- Meta row -->
        <div class="fade-up fade-up-2 post-meta">
          <div class="post-author">
            <div class="post-avatar" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="#fff" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="7" r="4" stroke="#fff" stroke-width="1.75"/></svg>
            </div>
            <span class="post-author-name">{t('blog.author')}</span>
          </div>
          <span class="post-meta-dim">{formatDate(post.publishedAt)}</span>
          <span class="post-meta-dim" aria-hidden="true">·</span>
          <span class="post-meta-dim">{readingLabel}</span>
          {heroCategoryLabel && (
            <>
              <span class="post-meta-dim" aria-hidden="true">·</span>
              <span class="post-meta-dim">{heroCategoryLabel}</span>
            </>
          )}
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════ MAIN POST LAYOUT ═══════════════════════════════ -->
  <section class="post-section">
    <div class="post-layout">

      <!-- ── MAIN ARTICLE ── -->
      <article>

        <!-- Hero image (only rendered when the post actually has a cover image) -->
        {post.coverImage?.asset?.url && (
          <div class="hero-img reveal" style={`background: ${coverGradient};`}>
            <img src={post.coverImage.asset.url} alt={post.title} />
            <div class="hero-img-overlay" style={`background: linear-gradient(to top, ${coverTint} 0%, transparent 50%);`}></div>
            <div class="hero-img-tint"></div>
          </div>
        )}

        <!-- Article body -->
        <div class="article-body" set:html={bodyHtml} />

        <!-- Share row -->
        <div class="reveal share-row">
          <span class="share-row-label">{t('blog.share')}</span>
          <a class="share-btn" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(postUrl)}`} target="_blank" rel="noopener noreferrer">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            X / Twitter
          </a>
          <a class="share-btn" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`} target="_blank" rel="noopener noreferrer">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/><circle cx="4" cy="4" r="2" stroke="currentColor" stroke-width="1.75"/></svg>
            LinkedIn
          </a>
          <button id="copy-link-btn" class="share-btn" data-copy={t('blog.copyLink')} data-copied={t('blog.copied')} type="button">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="copy-label">{t('blog.copyLink')}</span>
          </button>
        </div>

      </article>


      <!-- ── SIDEBAR ── -->
      <aside class="post-sidebar">

        <!-- Table of contents -->
        {headings.length > 0 && (
          <div class="sidebar-card">
            <div class="sidebar-eyebrow">{t('common.onThisPage')}</div>
            <nav class="toc-nav" id="toc-nav" aria-label={t('common.aria.tableOfContents')}>
              {headings.map((h, idx) => (
                <a href={`#${h.id}`} class={`sidebar-link${idx === 0 ? ' active' : ''}`}>{h.text}</a>
              ))}
            </nav>
          </div>
        )}

        <!-- CTA card -->
        <div class="sidebar-cta">
          <div class="sidebar-cta-blob" aria-hidden="true"></div>
          <div class="sidebar-cta-title">{t('blog.tryTitle')}</div>
          <p class="sidebar-cta-body">{t('blog.tryCopy')}</p>
          <a class="sidebar-cta-btn" href={`/${lang}/api-compare`}>
            {t('blog.tryButton')}
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <!-- Article info -->
        <div class="sidebar-card sidebar-info">
          <div class="sidebar-info-eyebrow">{t('blog.articleInfo')}</div>
          <div class="sidebar-info-rows">
            <div class="sidebar-info-row">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#999" stroke-width="1.75"/><path d="M12 6v6l4 2" stroke="#999" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>{readingLabel}</span>
            </div>
            <div class="sidebar-info-row">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="18" rx="2" stroke="#999" stroke-width="1.75"/><path d="M16 2v4M8 2v4M3 10h18" stroke="#999" stroke-width="1.75" stroke-linecap="round"/></svg>
              <span>{formatDate(post.publishedAt)}</span>
            </div>
            {heroCategoryLabel && (
              <div class="sidebar-info-row">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z" stroke="#999" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/><circle cx="7" cy="7" r="1" fill="#999"/></svg>
                <span>{heroCategoryLabel}</span>
              </div>
            )}
          </div>
        </div>

      </aside>

    </div>
  </section>


  <!-- ═══════════════════════════════ RELATED ARTICLES ═══════════════════════════════ -->
  {related.length > 0 && (
    <section class="related-section">
      <div class="related-wrap">
        <div class="related-head">
          <div class="related-heading">{t('blog.relatedArticles')}</div>
          <a class="related-viewall" href={`/${lang}/blog`}>
            {t('blog.viewAllArticles')}
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="related-grid reveal">
          {related.map(r => {
            const pill = catPill(r.category);
            const gradient = r.category ? CAT_GRADIENT[r.category] ?? CAT_GRADIENT.fundamentals : CAT_GRADIENT.fundamentals;
            const tint = r.category ? CAT_TINT[r.category] ?? CAT_TINT.fundamentals : CAT_TINT.fundamentals;
            return (
              <a class="related-card" href={`/${lang}/blog/${r.slug.current}`}>
                {r.coverImage?.asset?.url && (
                  <div class="related-img-wrap" style={`background: ${gradient};`}>
                    <img class="related-img" src={r.coverImage.asset.url} alt="" loading="lazy" />
                    <div class="related-img-overlay" style={`background: linear-gradient(to top, ${tint} 0%, transparent 60%);`}></div>
                  </div>
                )}
                <div class="related-body">
                  {r.category && (
                    <span class={`tag-pill tag-${pill}`} style="margin-bottom: 0.75rem;">{catLabel(r.category)}</span>
                  )}
                  <h3 class="related-title">{r.title}</h3>
                  <span class="related-date">{formatDate(r.publishedAt)}</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

</BaseLayout>

<style>
  /* ── Reading progress bar ──────────────────────────────────────────── */
  #read-progress {
    position: fixed;
    top: 0; left: 0;
    height: 3px;
    width: 100%;
    background: linear-gradient(90deg, #6155F1, #3E81E5);
    transform: scaleX(0);
    transform-origin: left;
    z-index: 200;
    transition: transform 0.1s linear;
    pointer-events: none;
  }

  /* ── Hero ──────────────────────────────────────────────────────────── */
  .post-hero {
    background:
      radial-gradient(ellipse 80% 60% at 70% 0%, rgba(97, 85, 241, 0.1) 0%, transparent 55%),
      radial-gradient(ellipse 40% 50% at 5% 100%, rgba(62, 129, 229, 0.08) 0%, transparent 50%),
      #F5F2FF;
    padding: 3rem 1.5rem 2.5rem;
  }
  .post-hero-inner { max-width: 1200px; margin: 0 auto; }

  .post-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
    font-size: 0.8rem;
    color: #999;
    flex-wrap: wrap;
  }
  .post-breadcrumb a {
    color: #999;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .post-breadcrumb a:hover { color: #6155F1; }
  .post-breadcrumb a:focus-visible { outline: 2px solid #6155F1; outline-offset: 2px; border-radius: 4px; }
  .post-breadcrumb-current { color: #6155F1; font-weight: 600; }

  .post-hero-col { max-width: 800px; }

  .post-hero-tags {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .post-title {
    font-family: 'Kanit', sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    color: #1C1C1C;
    letter-spacing: -0.04em;
    line-height: 1.15;
    margin: 0 0 1.125rem 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(97, 85, 241, 0.12);
  }
  .post-author {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .post-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6155F1, #3E81E5);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .post-author-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: #3C315B;
  }
  .post-meta-dim {
    font-size: 0.8rem;
    color: #999;
  }

  /* ── Tag pills (per-category color) ────────────────────────────────── */
  .tag-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    background: #E2DFFE;
    color: #6155F1;
    text-decoration: none;
    transition: background-color 0.15s ease;
    white-space: nowrap;
  }
  .tag-purple { background: #E2DFFE; color: #6155F1; }
  .tag-purple:hover { background: #d0cbfd; }
  .tag-blue   { background: #EBF4FF; color: #3E81E5; }
  .tag-blue:hover   { background: #d5e7ff; }
  .tag-dark   { background: #F4F2F4; color: #3C315B; }
  .tag-dark:hover   { background: #e9e6e9; }
  .tag-green  { background: #F0FFF4; color: #2D8653; }
  .tag-green:hover  { background: #d8f5e1; }
  .tag-amber  { background: #FFF4E2; color: #B07D2E; }
  .tag-amber:hover  { background: #ffe7c2; }

  /* ── Layout ────────────────────────────────────────────────────────── */
  .post-section { padding: 3rem 1.5rem 5rem; }
  .post-layout {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 3.5rem;
    align-items: start;
  }
  .post-sidebar {
    position: sticky;
    top: 88px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── Hero image ────────────────────────────────────────────────────── */
  .hero-img {
    border-radius: 18px;
    overflow: hidden;
    height: 420px;
    margin-bottom: 2.5rem;
    position: relative;
  }
  .hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hero-img-overlay { position: absolute; inset: 0; }
  .hero-img-tint {
    position: absolute;
    inset: 0;
    background: rgba(97, 85, 241, 0.15);
    mix-blend-mode: multiply;
  }

  /* ── Article body typography ───────────────────────────────────────── */
  .article-body :global(h2) {
    font-family: 'Kanit', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: #1C1C1C;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-top: 2.5rem;
    margin-bottom: 0.875rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(97, 85, 241, 0.1);
  }
  .article-body :global(h2:first-child) {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }
  .article-body :global(h3) {
    font-family: 'Kanit', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #1C1C1C;
    letter-spacing: -0.02em;
    margin-top: 1.75rem;
    margin-bottom: 0.625rem;
  }
  .article-body :global(p) {
    font-size: 0.975rem;
    line-height: 1.85;
    color: #444;
    margin-bottom: 1.125rem;
  }
  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 1.375rem;
    margin-bottom: 1.125rem;
  }
  .article-body :global(li) {
    font-size: 0.975rem;
    line-height: 1.8;
    color: #444;
    margin-bottom: 0.375rem;
  }
  .article-body :global(strong) { color: #1C1C1C; font-weight: 700; }
  .article-body :global(a) {
    color: #6155F1;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.15s ease;
  }
  .article-body :global(a:hover) { color: #4e44d4; }
  .article-body :global(code) {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.85em;
    background: #E2DFFE;
    color: #3C315B;
    padding: 0.15rem 0.45rem;
    border-radius: 5px;
  }
  .article-body :global(blockquote) {
