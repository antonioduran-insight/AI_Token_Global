  .post-title {
    font-family: 'Kanit', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: #1C1C1C;
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin: 0 0 0.625rem 0;
