    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    position: relative;
    overflow: hidden;
  }
  .newsletter-blob {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
  .newsletter-blob-1 {
    top: -40px;
    right: -40px;
    width: 200px;
    height: 200px;
    background: rgba(255, 255, 255, 0.06);
  }
  .newsletter-blob-2 {
    bottom: -60px;
