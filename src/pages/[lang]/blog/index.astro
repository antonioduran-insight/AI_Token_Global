    .newsletter-banner { padding: 2.25rem 1.75rem; }
    .newsletter-form input { min-width: 0; flex: 1; }
  }
</style>

<script>
  (function () {
    const POSTS_PER_PAGE = 12;
    const tabs = document.querySelectorAll<HTMLButtonElement>('.cat-tab');
    const featuredCards = document.querySelectorAll<HTMLAnchorElement>('.featured-card');
    const gridCards = document.querySelectorAll<HTMLAnchorElement>('.post-card');
    const emptyState = document.getElementById('filter-empty');
    const postCountEl = document.getElementById('post-count');
    const postTotalEl = document.getElementById('post-total');
    const pageStatus  = document.getElementById('page-status');
    const pageNumbers = document.getElementById('page-numbers');
    const prevBtn = document.querySelector<HTMLAnchorElement>('.page-prev');
    const nextBtn = document.querySelector<HTMLAnchorElement>('.page-next');
    const paginationEl = document.querySelector<HTMLElement>('.pagination');
    const pageOfTpl = paginationEl?.dataset.template ?? '';

    let currentFilter = 'all';
    let currentPage = 1;

    function pageOf(n: number, total: number) {
      return pageOfTpl.replace('{n}', String(n)).replace('{total}', String(total));
    }

    function buildPageNumbers(total: number, current: number) {
      if (!pageNumbers) return;
      pageNumbers.innerHTML = '';
      const append = (html: string) => { pageNumbers.insertAdjacentHTML('beforeend', html); };
      const btn = (n: number) =>
        `<a href="#" class="page-btn${n === current ? ' active' : ''}" data-page="${n}">${n}</a>`;

      if (total <= 7) {
        for (let i = 1; i <= total; i++) append(btn(i));
        return;
      }
      // Match archive's "1 2 3 … 17" pattern: anchor the first 3 and the last,
      // plus the current page's neighbourhood when it falls outside.
      const showSet = new Set<number>([1, 2, 3, total, current - 1, current, current + 1]);
      const sorted = [...showSet].filter(n => n >= 1 && n <= total).sort((a, b) => a - b);
      let prev = 0;
      for (const n of sorted) {
        if (n - prev > 1) append('<span class="page-ellipsis" aria-hidden="true">···</span>');
        append(btn(n));
        prev = n;
      }
    }

    function getMatching(filter: string) {
      const matching: HTMLAnchorElement[] = [];
      gridCards.forEach(card => {
        const cat = card.dataset.category ?? 'uncategorized';
        if (filter === 'all' || cat === filter) matching.push(card);
      });
      return matching;
    }

    function pickFeatured(filter: string) {
      // First matching post becomes the featured slot
      let featuredIdx = -1;
      featuredCards.forEach(card => {
        const cat = card.dataset.category ?? 'uncategorized';
        if (featuredIdx === -1 && (filter === 'all' || cat === filter)) {
          featuredIdx = Number(card.dataset.idx);
        }
        card.classList.add('hidden-post');
      });
      if (featuredIdx >= 0) {
        const target = [...featuredCards].find(c => Number(c.dataset.idx) === featuredIdx);
        if (target) target.classList.remove('hidden-post');
      }
      return featuredIdx;
    }

    function render() {
      const featuredIdx = pickFeatured(currentFilter);
      const matching = getMatching(currentFilter).filter(c => Number(c.dataset.idx) !== featuredIdx);
      const total = matching.length;
      const totalPages = Math.max(1, Math.ceil(total / POSTS_PER_PAGE));
      if (currentPage > totalPages) currentPage = totalPages;
      if (currentPage < 1) currentPage = 1;

      const start = (currentPage - 1) * POSTS_PER_PAGE;
      const end = start + POSTS_PER_PAGE;

      // Hide everything first
      gridCards.forEach(c => c.classList.add('hidden-post'));
      // Show this page's slice
      matching.slice(start, end).forEach(c => c.classList.remove('hidden-post'));

      const visible = Math.max(0, Math.min(POSTS_PER_PAGE, total - start));
      if (postCountEl) postCountEl.textContent = String(visible);
      if (postTotalEl) postTotalEl.textContent = String(total + (featuredIdx >= 0 ? 1 : 0));

      // Pagination chrome
      if (paginationEl) {
        paginationEl.style.display = totalPages > 1 ? '' : 'none';
        buildPageNumbers(totalPages, currentPage);
        if (pageStatus) pageStatus.textContent = pageOf(currentPage, totalPages);
        if (prevBtn) {
          if (currentPage <= 1) prevBtn.setAttribute('aria-disabled', 'true');
          else prevBtn.removeAttribute('aria-disabled');
        }
        if (nextBtn) {
          if (currentPage >= totalPages) nextBtn.setAttribute('aria-disabled', 'true');
          else nextBtn.removeAttribute('aria-disabled');
        }
      }

      // Empty state
      const featuredVisible = featuredIdx >= 0;
      if (emptyState) emptyState.style.display = !featuredVisible && visible === 0 ? 'block' : 'none';
    }

    // Tab clicks
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => {
          t.classList.toggle('active', t === tab);
          t.setAttribute('aria-selected', String(t === tab));
        });
        currentFilter = tab.dataset.filter ?? 'all';
        currentPage = 1;
        render();
      });
    });

    // Pagination delegation
    paginationEl?.addEventListener('click', (e) => {
      const target = (e.target as HTMLElement).closest<HTMLAnchorElement>('a.page-btn');
      if (!target) return;
      e.preventDefault();
      if (target.getAttribute('aria-disabled') === 'true') return;

      if (target.classList.contains('page-prev')) currentPage--;
      else if (target.classList.contains('page-next')) currentPage++;
      else if (target.dataset.page) currentPage = Number(target.dataset.page);

      render();
      // Scroll the grid into view
      document.getElementById('post-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    render();
  })();
</script>
