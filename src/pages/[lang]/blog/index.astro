  .post-date { font-size: 0.775rem; color: #999; font-weight: 500; }
  .post-read {
    font-size: 0.775rem;
    color: #6155F1;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    transition: gap 0.18s ease;
  }
  .post-card:hover .post-read { gap: 0.5rem; }

  /* ── Pagination ────────────────────────────────────────────────────── */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .page-numbers { display: inline-flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
  /* page-btn / page-ellipsis are :global because the page-numbers are injected by JS
     after build, so Astro's scoped attribute isn't on them. */
  :global(.page-btn) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 9px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.825rem;
    font-weight: 600;
    color: #3C315B;
    background: #fff;
    border: 1.5px solid rgba(97, 85, 241, 0.15);
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    text-decoration: none;
  }
  :global(.page-btn:hover) { background: #EDE9FF; color: #6155F1; border-color: rgba(97, 85, 241, 0.3); }
  :global(.page-btn:focus-visible) { outline: 2px solid #6155F1; outline-offset: 2px; }
  :global(.page-btn.active) { background: #6155F1; color: #fff; border-color: #6155F1; }
  :global(.page-btn[aria-disabled="true"]) { opacity: 0.35; pointer-events: none; cursor: not-allowed; }
  :global(.page-ellipsis) {
    font-size: 0.825rem;
    color: #999;
    padding: 0 0.25rem;
    user-select: none;
  }
  .page-status {
    font-size: 0.8rem;
    color: #999;
    margin-left: 0.5rem;
    font-weight: 500;
  }

  /* ── Newsletter banner ─────────────────────────────────────────────── */
  .newsletter-banner {
    background: linear-gradient(135deg, #6155F1 0%, #3E81E5 100%);
    border-radius: 20px;
    padding: 3rem 2.5rem;
    display: flex;
