  .newsletter-form button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.2);
  }
  .newsletter-form button:active { transform: translateY(0); }
  .newsletter-form button:focus-visible { outline: 2px solid #fff; outline-offset: 3px; }

  /* ── Visibility helper ─────────────────────────────────────────────── */
  .hidden-post { display: none !important; }

  /* ── Responsive ────────────────────────────────────────────────────── */
  @media (max-width: 1023px) {
    .featured-inner { flex-direction: column !important; }
    .featured-img { width: 100% !important; min-height: 0 !important; height: 220px !important; }
    .post-grid { grid-template-columns: repeat(2, 1fr) !important; }
    .featured-content { padding: 2rem !important; }
  }
  @media (max-width: 640px) {
    .post-grid { grid-template-columns: 1fr !important; }
    .cat-scroll { gap: 0.5rem !important; }
    .cat-tab { font-size: 0.78rem; padding: 0.4rem 0.875rem; }
