  }
  .cta-secondary:hover { background-color: rgba(255,255,255,0.25); transform: translateY(-2px); }

  /* Responsive */
  @media (max-width: 1024px) {
    .calc-grid { grid-template-columns: 1fr; }
    .faq-grid { grid-template-columns: 1fr; gap: 2rem; }
