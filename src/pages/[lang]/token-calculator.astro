</style>

<script is:inline define:vars={{ calcI18n: { lowest: t('calculator.summaryLowest'), highest: t('calculator.summaryHighest'), inputCostOnly: t('calculator.inputCostOnly') } }}>
  window.__CALC_I18N__ = calcI18n;
</script>

<script is:inline>
  /* Reveal */
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

  /* Token calculator logic */
  const textInput      = document.getElementById('textInput');
  const chineseCountEl = document.getElementById('chineseCount');
  const englishCountEl = document.getElementById('englishCount');
  const symbolCountEl  = document.getElementById('symbolCount');
  const inputTokenEl   = document.getElementById('inputToken');
  const openaiCostEl   = document.getElementById('openaiCost');
  const claudeCostEl   = document.getElementById('claudeCost');
  const geminiCostEl   = document.getElementById('geminiCost');
  const resultSummaryEl = document.getElementById('resultSummary');
  const charCountEl    = document.getElementById('charCount');

  const pricing = { openai: 2.5, claude: 5, gemini: 2 };
  const platformNames = { openai: 'OpenAI', claude: 'Anthropic', gemini: 'Google' };

  const SUMMARY_PLACEHOLDER = resultSummaryEl ? resultSummaryEl.textContent.trim() : '';
  const SUMMARY_LOWEST = (window.__CALC_I18N__ && window.__CALC_I18N__.lowest) || '';
  const SUMMARY_HIGHEST = (window.__CALC_I18N__ && window.__CALC_I18N__.highest) || '';
  const SUMMARY_INPUT_ONLY = (window.__CALC_I18N__ && window.__CALC_I18N__.inputCostOnly) || '';

  function formatCost(val) { return '$' + val.toFixed(6); }

  function getExtremes(costMap) {
    const vals = Object.values(costMap);
    const min = Math.min.apply(null, vals);
    const max = Math.max.apply(null, vals);
    const minPlatforms = Object.keys(costMap).filter(k => costMap[k] === min).map(k => platformNames[k]);
    const maxPlatforms = Object.keys(costMap).filter(k => costMap[k] === max).map(k => platformNames[k]);
    return { min: min, max: max, minPlatforms: minPlatforms, maxPlatforms: maxPlatforms };
  }

  function updateSummary(text, costMap) {
    if (!text.trim()) {
      resultSummaryEl.textContent = SUMMARY_PLACEHOLDER;
      resultSummaryEl.style.background = '#F0EEFF';
      resultSummaryEl.style.borderColor = 'rgba(97,85,241,0.18)';
      resultSummaryEl.style.color = '#3C315B';
      return;
    }
    const ex = getExtremes(costMap);
    const minText = ex.minPlatforms.length > 1
      ? SUMMARY_LOWEST + ': ' + ex.minPlatforms.join(' & ')
      : SUMMARY_LOWEST + ': <strong>' + ex.minPlatforms[0] + '</strong>';
    const maxText = ex.maxPlatforms.length > 1
      ? SUMMARY_HIGHEST + ': ' + ex.maxPlatforms.join(' & ')
      : SUMMARY_HIGHEST + ': <strong>' + ex.maxPlatforms[0] + '</strong>';
    resultSummaryEl.innerHTML = minText + ' &nbsp;·&nbsp; ' + maxText + ' &nbsp;·&nbsp; ' + SUMMARY_INPUT_ONLY;
    resultSummaryEl.style.background = '#EDF7ED';
    resultSummaryEl.style.borderColor = 'rgba(22,163,74,0.2)';
    resultSummaryEl.style.color = '#166534';
  }

  function updateCostColor(el, cost, min, max) {
    el.classList.remove('cheapest', 'priciest', 'neutral');
    if (cost === min && min !== max) el.classList.add('cheapest');
    else if (cost === max && min !== max) el.classList.add('priciest');
    else el.classList.add('neutral');
  }

  function calculateTokens() {
    const text = textInput.value || '';

    // GA4: fire calculator_used once, the first time the user actually enters text.
    if (!window.__gaCalcUsed && text.trim().length > 0) {
      window.__gaCalcUsed = true;
      if (typeof window.gtag === 'function') window.gtag('event', 'calculator_used', {});
    }

    charCountEl.textContent = text.length.toLocaleString();

    const chineseMatches = text.match(/[一-鿿]/g) || [];
    const englishWordMatches = text.match(/[A-Za-z]+(?:'[A-Za-z]+)*/g) || [];
    const numberMatches = text.match(/[0-9]/g) || [];

    const chineseCount = chineseMatches.length;
    const englishCount = englishWordMatches.length;
    const numberCount  = numberMatches.length;

    const stripped = text
      .replace(/[一-鿿]/g, '')
      .replace(/[A-Za-z]+(?:'[A-Za-z]+)*/g, '')
      .replace(/[0-9]/g, '');
    const symbolCount = (stripped.match(/[^\s]/g) || []).length + numberCount;

    const inputTokens = Math.round(chineseCount * 1.5 + englishCount * 1.1 + symbolCount * 0.3);

    const openaiCost = (inputTokens * pricing.openai) / 1000000;
    const claudeCost = (inputTokens * pricing.claude) / 1000000;
    const geminiCost = (inputTokens * pricing.gemini) / 1000000;

    chineseCountEl.textContent = chineseCount.toLocaleString();
    englishCountEl.textContent = englishCount.toLocaleString();
    symbolCountEl.textContent  = symbolCount.toLocaleString();
    inputTokenEl.textContent   = inputTokens.toLocaleString();

    openaiCostEl.textContent = formatCost(openaiCost);
    claudeCostEl.textContent = formatCost(claudeCost);
    geminiCostEl.textContent = formatCost(geminiCost);

    const costMap = { openai: openaiCost, claude: claudeCost, gemini: geminiCost };
    const ex = getExtremes(costMap);
    updateCostColor(openaiCostEl, openaiCost, ex.min, ex.max);
    updateCostColor(claudeCostEl, claudeCost, ex.min, ex.max);
    updateCostColor(geminiCostEl, geminiCost, ex.min, ex.max);

    updateSummary(text, costMap);
  }

  function clearAll() {
    textInput.value = '';
    charCountEl.textContent = '0';
    chineseCountEl.textContent = '0';
    englishCountEl.textContent = '0';
    symbolCountEl.textContent  = '0';
    inputTokenEl.textContent   = '0';
    openaiCostEl.textContent = '$0.000000';
    claudeCostEl.textContent = '$0.000000';
    geminiCostEl.textContent = '$0.000000';
    [openaiCostEl, claudeCostEl, geminiCostEl].forEach(el => {
      el.classList.remove('cheapest', 'priciest');
      el.classList.add('neutral');
    });
    resultSummaryEl.textContent = SUMMARY_PLACEHOLDER;
    resultSummaryEl.style.background = '#F0EEFF';
    resultSummaryEl.style.borderColor = 'rgba(97,85,241,0.18)';
    resultSummaryEl.style.color = '#3C315B';
    textInput.focus();
  }

  document.getElementById('clearBtn').addEventListener('click', clearAll);
  textInput.addEventListener('input', calculateTokens);
  textInput.addEventListener('paste', () => setTimeout(calculateTokens, 0));
</script>
