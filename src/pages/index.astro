---
const siteOrigin = (Astro.site ?? new URL('https://www.aitoken.global')).origin;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI Token | AI Pricing, Token Calculator &amp; API Comparison</title>
  <meta name="description" content="The global guide to AI tokens — understand pricing, compare models, and calculate costs across OpenAI, Anthropic, Google, and more." />

  <!-- Canonical -->
  <link rel="canonical" href={`${siteOrigin}/en/`} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`${siteOrigin}/`} />
  <meta property="og:title" content="AI Token | AI Pricing, Token Calculator &amp; API Comparison" />
  <meta property="og:description" content="The global guide to AI tokens — understand pricing, compare models, and calculate costs across OpenAI, Anthropic, Google, and more." />
  <meta property="og:image" content={`${siteOrigin}/og-image.png`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:site_name" content="AI Token" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="AI Token | AI Pricing, Token Calculator &amp; API Comparison" />
  <meta name="twitter:description" content="The global guide to AI tokens — understand pricing, compare models, and calculate costs across OpenAI, Anthropic, Google, and more." />
  <meta name="twitter:image" content={`${siteOrigin}/og-image.png`} />

  <!-- Redirect users immediately; scrapers read the tags above -->
  <meta http-equiv="refresh" content="0;url=/en/" />
</head>
<body>
  <script>window.location.replace('/en/');</script>
</body>
</html>
