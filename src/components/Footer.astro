---
import { useTranslations } from '../i18n/index';
import type { Lang } from '../i18n/index';

export interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const copyright = t('footer.copyright').replace('{year}', String(new Date().getFullYear()));
---

<footer style="background: #1C1C1C; color: #999; padding: 3.5rem 1.5rem 2rem;">
  <div style="max-width: 1200px; margin: 0 auto;">
    <div class="footer-grid" style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; margin-bottom: 3rem;">

      <div>
        <div style="display: flex; align-items: center; gap: 0.625rem; margin-bottom: 1rem;">
          <img src="/AI_Token_logoPNG.avif" alt="AI Token King" style="width: 32px; height: 32px; object-fit: contain;" />
          <span style="font-family: 'Kanit', sans-serif; font-size: 1rem; font-weight: 700; color: #FFFFFF; letter-spacing: -0.02em;">AI Token King</span>
        </div>
        <p style="font-size: 0.875rem; line-height: 1.75; color: #666; max-width: 260px;">
          {t('footer.tagline')}
        </p>
        <div style="display: flex; gap: 0.625rem; margin-top: 1rem;">
          <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" style="width: 36px; height: 36px; border-radius: 8px; background: #2A2A2A; display: flex; align-items: center; justify-content: center; transition: background-color 0.18s ease;" onmouseover="this.style.backgroundColor='#6155F1'" onmouseout="this.style.backgroundColor='#2A2A2A'">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#999"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" style="width: 36px; height: 36px; border-radius: 8px; background: #2A2A2A; display: flex; align-items: center; justify-content: center; transition: background-color 0.18s ease;" onmouseover="this.style.backgroundColor='#6155F1'" onmouseout="this.style.backgroundColor='#2A2A2A'">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#999"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <div style="font-family: 'Kanit', sans-serif; font-size: 0.875rem; font-weight: 700; color: #FFFFFF; margin-bottom: 1.125rem; letter-spacing: 0.02em; text-transform: uppercase;">{t('footer.learn')}</div>
        <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.625rem;">
          <li><a href={`/${lang}/beginners-guide`} style="font-size: 0.875rem; color: #666; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#666'">{t('footer.beginnersGuide')}</a></li>
          <li><a href={`/${lang}/token-calculator`} style="font-size: 0.875rem; color: #666; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#666'">{t('footer.tokenCalculator')}</a></li>
          <li><a href={`/${lang}/use-cases`} style="font-size: 0.875rem; color: #666; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#666'">{t('footer.useCases')}</a></li>
          <li><a href={`/${lang}/user-guide`} style="font-size: 0.875rem; color: #666; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#666'">{t('footer.userGuide')}</a></li>
        </ul>
      </div>

      <div>
        <div style="font-family: 'Kanit', sans-serif; font-size: 0.875rem; font-weight: 700; color: #FFFFFF; margin-bottom: 1.125rem; letter-spacing: 0.02em; text-transform: uppercase;">{t('footer.compare')}</div>
        <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.625rem;">
          <li><a href={`/${lang}/api-compare`} style="font-size: 0.875rem; color: #666; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#666'">{t('footer.apiComparison')}</a></li>
          <li><a href={`/${lang}/chatgpt-api`} style="font-size: 0.875rem; color: #666; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#666'">{t('footer.chatgptApi')}</a></li>
          <li><a href={`/${lang}/claude-api`} style="font-size: 0.875rem; color: #666; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#666'">{t('footer.claudeApi')}</a></li>
          <li><a href={`/${lang}/gemini-api`} style="font-size: 0.875rem; color: #666; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#666'">{t('footer.geminiApi')}</a></li>
        </ul>
      </div>

      <div>
        <div style="font-family: 'Kanit', sans-serif; font-size: 0.875rem; font-weight: 700; color: #FFFFFF; margin-bottom: 1.125rem; letter-spacing: 0.02em; text-transform: uppercase;">{t('footer.more')}</div>
        <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.625rem;">
          <li><a href={`/${lang}/blog`} style="font-size: 0.875rem; color: #666; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#666'">{t('nav.blog')}</a></li>
          <li><a href={`/${lang}/ai-trends`} style="font-size: 0.875rem; color: #666; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#666'">{t('footer.aiTrends')}</a></li>
          <li><a href={`/${lang}/compliance`} style="font-size: 0.875rem; color: #666; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#666'">{t('footer.compliance')}</a></li>
          <li><a href="https://www.aitokenking.com.tw/docs" target="_blank" rel="noopener noreferrer" style="font-size: 0.875rem; color: #666; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#666'">{t('footer.documentation')}</a></li>
        </ul>
      </div>

    </div>

    <div style="border-top: 1px solid #2A2A2A; padding-top: 1.75rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
      <p style="font-size: 0.8rem; color: #555; margin: 0;">{copyright}</p>
      <div style="display: flex; gap: 1.5rem;">
        <a href="#" style="font-size: 0.8rem; color: #555; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#555'">{t('footer.privacy')}</a>
        <a href="#" style="font-size: 0.8rem; color: #555; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#555'">{t('footer.terms')}</a>
      </div>
    </div>
  </div>
</footer>
