---
import { useTranslations } from '../i18n/index';
import type { Lang } from '../i18n/index';

export interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<footer style="background: #1C1C1C; color: #999; padding: 3.5rem 1.5rem 2rem;">
  <div style="max-width: 1200px; margin: 0 auto;">
    <div class="footer-grid" style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; margin-bottom: 3rem;">

      <div>
        <div style="display: flex; align-items: center; gap: 0.625rem; margin-bottom: 1rem;">
          <img src="/AI_Token_logoPNG.avif" alt="AI Token King" style="width: 32px; height: 32px; object-fit: contain;" />
          <span style="font-family: 'Kanit', sans-serif; font-size: 1rem; font-weight: 700; color: #FFFFFF; letter-spacing: -0.02em;">AI Token King</span>
        </div>
        <p style="font-size: 0.875rem; line-height: 1.75; color: #999; max-width: 260px;">
          {t('footer.tagline')}
        </p>
      </div>

      <div>
        <div style="font-family: 'Kanit', sans-serif; font-size: 0.875rem; font-weight: 700; color: #FFFFFF; margin-bottom: 1.125rem; letter-spacing: 0.02em; text-transform: uppercase;">{t('footer.learn')}</div>
        <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.625rem;">
          <li><a href={`/${lang}/beginners-guide`} style="font-size: 0.875rem; color: #999; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#999'">{t('footer.beginnersGuide')}</a></li>
          <li><a href={`/${lang}/token-calculator`} style="font-size: 0.875rem; color: #999; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#999'">{t('footer.tokenCalculator')}</a></li>
          <li><a href={`/${lang}/use-cases`} style="font-size: 0.875rem; color: #999; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#999'">{t('footer.useCases')}</a></li>
          <li><a href={`/${lang}/user-guide`} style="font-size: 0.875rem; color: #999; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#999'">{t('footer.userGuide')}</a></li>
        </ul>
      </div>

      <div>
        <div style="font-family: 'Kanit', sans-serif; font-size: 0.875rem; font-weight: 700; color: #FFFFFF; margin-bottom: 1.125rem; letter-spacing: 0.02em; text-transform: uppercase;">{t('footer.compare')}</div>
        <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.625rem;">
          <li><a href={`/${lang}/api-compare`} style="font-size: 0.875rem; color: #999; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#999'">{t('footer.apiComparison')}</a></li>
          <li><a href={`/${lang}/chatgpt-api`} style="font-size: 0.875rem; color: #999; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#999'">{t('footer.chatgptApi')}</a></li>
          <li><a href={`/${lang}/claude-api`} style="font-size: 0.875rem; color: #999; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#999'">{t('footer.claudeApi')}</a></li>
          <li><a href={`/${lang}/gemini-api`} style="font-size: 0.875rem; color: #999; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#999'">{t('footer.geminiApi')}</a></li>
        </ul>
      </div>

      <div>
        <div style="font-family: 'Kanit', sans-serif; font-size: 0.875rem; font-weight: 700; color: #FFFFFF; margin-bottom: 1.125rem; letter-spacing: 0.02em; text-transform: uppercase;">{t('footer.more')}</div>
        <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.625rem;">
          <li><a href={`/${lang}/blog`} style="font-size: 0.875rem; color: #999; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#999'">{t('nav.blog')}</a></li>
          <li><a href={`/${lang}/ai-trends`} style="font-size: 0.875rem; color: #999; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#999'">{t('footer.aiTrends')}</a></li>
          <li><a href={`/${lang}/compliance`} style="font-size: 0.875rem; color: #999; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#999'">{t('footer.compliance')}</a></li>
          <li><a href="https://www.aitokenking.com.tw/docs" target="_blank" rel="noopener noreferrer" style="font-size: 0.875rem; color: #999; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#999'">{t('footer.documentation')}</a></li>
        </ul>
      </div>

    </div>

    <div style="border-top: 1px solid #2A2A2A; padding-top: 1.75rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
      <p style="font-size: 0.8rem; color: #888; margin: 0;">{t('footer.copyright')}</p>
      <div style="display: flex; gap: 1.5rem;">
        <a href="#" style="font-size: 0.8rem; color: #888; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#888'">{t('footer.privacy')}</a>
        <a href="#" style="font-size: 0.8rem; color: #888; text-decoration: none; transition: color 0.15s ease;" onmouseover="this.style.color='#E2DFFE'" onmouseout="this.style.color='#888'">{t('footer.terms')}</a>
      </div>
    </div>
  </div>
</footer>
