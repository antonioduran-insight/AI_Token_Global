---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { useTranslations, SUPPORTED_LANGS, LANG_META } from '../i18n/index';
import type { Lang } from '../i18n/index';
import type { SeoData } from '../lib/sanity';

export interface Props {
  title: string;
  description?: string;
  seo?: SeoData;
  noindex?: boolean;
  activePage?: string;
  activeDropdown?: string;
  lang?: Lang;
}

const {
  title,
  description,
  seo,
  noindex = false,
  activePage = '',
  activeDropdown = '',
  lang = 'en',
} = Astro.props;

const t = useTranslations(lang as Lang);
const siteOrigin = (Astro.site ?? new URL('https://aitokenglobal.com')).origin;
const canonicalURL = new URL(Astro.url.pathname, siteOrigin).href;

const seoTitle = seo?.seoTitle ?? title;
const seoDescription = seo?.seoDescription ?? description ?? t('meta.defaultDescription');
const ogImageUrl = seo?.ogImage?.asset?.url ?? `${siteOrigin}/AI_Token_logoPNG.avif`;
const shouldNoindex = seo?.noindex ?? noindex;

const hreflangs = SUPPORTED_LANGS.map(l => ({
  lang: l,
  url: new URL(Astro.url.pathname.replace(`/${lang}/`, `/${l}/`), siteOrigin).href,
}));
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary meta -->
  <title>{seoTitle}</title>
  <meta name="description" content={seoDescription} />
  {shouldNoindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Canonical + hreflang -->
  <link rel="canonical" href={canonicalURL} />
  {hreflangs.map(h => <link rel="alternate" hreflang={h.lang} href={h.url} />)}
  <link rel="alternate" hreflang="x-default" href={hreflangs.find(h => h.lang === 'en')?.url ?? canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={seoTitle} />
  <meta property="og:description" content={seoDescription} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content={LANG_META[lang as Lang].locale.replace('-', '_')} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={seoTitle} />
  <meta name="twitter:description" content={seoDescription} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon-corgi.png" />
  <link rel="shortcut icon" href="/favicon.ico" />

  <!-- Google Fonts (non-blocking) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Kanit:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" />

  <!-- Tailwind CDN (defer — full build-step migration is Task #9) -->
  <!-- Pre-seed window.tailwind so the config assignment below doesn't throw
       before the deferred CDN script runs. Tailwind CDN reads .config on init. -->
  <script is:inline>window.tailwind = window.tailwind || {};</script>
  <script defer src="https://cdn.tailwindcss.com" is:inline></script>
  <script is:inline>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              purple: '#6155F1',
              blue: '#3E81E5',
              black: '#000000',
              gray: '#666666',
              lightgray: '#999999',
              pale: '#EBF4FF',
              white: '#FFFFFF',
              lavender: '#F5F2FF',
              softpurple: '#E2DFFE',
              darkpurple: '#3C315B',
            }
          },
          fontFamily: {
            heading: ['Kanit', 'sans-serif'],
            body: ['Plus Jakarta Sans', 'sans-serif'],
          },
          letterSpacing: {
            tightest: '-0.04em',
            tighter: '-0.03em',
          }
        }
      }
    }
  </script>
</head>
<body>
  <Nav activePage={activePage} activeDropdown={activeDropdown} lang={lang as Lang} />
  <main>
    <slot />
  </main>
  <Footer lang={lang as Lang} />

  <script is:inline>
    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // FAQ accordion — toggles .open class; CSS handles show/hide
    window.toggleFaq = function(btn) {
      const answer = btn.nextElementSibling;
      const chevron = btn.querySelector('.faq-chevron');
      const isOpen = answer.classList.contains('open');
      document.querySelectorAll('.faq-answer').forEach(a => a.classList.remove('open'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('open'));
      if (!isOpen) {
        answer.classList.add('open');
        chevron.classList.add('open');
      }
    };

    // Hero pointer blob — follows cursor with smooth lerp inside .hero-bg sections
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll('.hero-bg').forEach(hero => {
        const canvas = hero.querySelector('.hero-bg-canvas');
        if (!canvas) return;
        let pointer = canvas.querySelector('.blob-pointer');
        if (!pointer) {
          pointer = document.createElement('div');
          pointer.className = 'blob-pointer';
          (canvas.querySelector('.grad-blobs') || canvas).appendChild(pointer);
        }
        let cx = 0, cy = 0, tx = 0, ty = 0;
        function tick() {
          cx += (tx - cx) / 20;
          cy += (ty - cy) / 20;
          pointer.style.transform = 'translate(' + Math.round(cx) + 'px,' + Math.round(cy) + 'px)';
          requestAnimationFrame(tick);
        }
        hero.addEventListener('mousemove', e => {
          const r = hero.getBoundingClientRect();
          tx = e.clientX - r.left;
          ty = e.clientY - r.top;
        });
        tick();
      });
    }
  </script>
</body>
</html>
