# raw Make batch exports (processed copies live in scripts/data/posts-batch-*.json)
scripts/data/articles-batch-*.json

# defensive: prevent stray bare git clones from being committed if they ever land in the working tree
*.git/

# translation pipeline (intern: fetched English + translated output + reports)
translation/

# per-task progress docs (kept local — not part of the deliverable)
TASK*_PROGRESS.md

# persisted puppeteer profile used for screenshotting authenticated Sanity Studio
# (created locally by archive/sanity-auth-setup.mjs — never commit)
archive/.puppeteer-profile/
